@model WorldKitchen.Models.BigViewModel
@{
    ViewData["Title"] = "Country and Dishes Details";
    Layout = "/Views/Shared/_LayoutCountry.cshtml";
}
<h1> Armenia page </h1>
<!-- Displaying Country Table -->
@if (Model.CountryTable != null)
{
    <table>
        <thead>
            <tr>
                <th>Country Name</th>
                <!-- Other table headers -->
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.CountryTable)
            {
                <tr>
                    <td>@d.Country</td> <!-- Assuming Country has a Name property -->
                    <!-- Other data fields -->
                </tr>
            }
        </tbody>
    </table>
}

<!-- Displaying Dish Table -->
@if (Model.DishTable != null)
{
    <table>
        <thead>
            <tr>
                <th>Dish Name</th>
                <!-- Other table headers -->
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.DishTable)
            {
                <tr>
                    <td>@e.Name</td> <!-- Assuming Dish has a Name property -->
                    <!-- Other data fields -->
                </tr>
            }
        </tbody>
    </table>
}

