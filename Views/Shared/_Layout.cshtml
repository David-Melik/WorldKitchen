<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorldKitchen</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm customNavbar customNavbar bgDarkBlue border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                 <img class="logoNav"src="media/footerLogo.png" alt="logo">
                  WorldKitchen
                </a>
            </div> 
            @Html.Partial("_SearchBar")
            


       </nav>
    </header>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>

    <!-- Footer Section -->
    <footer>
        <div class="footer-content">
            <img class="footer-content-img"src="media/footerLogo.png" alt="logo">
            <div class="footer-text">
                <h3 class="footer-logo display-5">World Kitchen</h3>
                <p class="footer-slogan">The best place to learn how to cook international dishies</p>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
